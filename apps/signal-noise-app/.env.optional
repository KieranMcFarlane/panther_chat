DISCOVERY_SEARCH_TIMEOUT_SECONDS=12
DISCOVERY_SEARCH_VALIDATION_TIMEOUT_SECONDS=5
DISCOVERY_URL_RESOLUTION_TIMEOUT_SECONDS=12

