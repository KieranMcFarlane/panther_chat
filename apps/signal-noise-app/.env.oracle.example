# Copy to .env.oracle on the Oracle VM. Do not commit .env.oracle.

POSTGRES_DB=signal_noise_app
POSTGRES_USER=panther_staging
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_PUBLIC_BIND=0.0.0.0

FALKORDB_USER=falkordb
FALKORDB_PASSWORD=replace-with-a-long-random-password
FALKORDB_DATABASE=sports_intelligence

# Keep backend private by default. Set BACKEND_PUBLIC_BIND=0.0.0.0 only if Vercel must call FastAPI directly.
BACKEND_PUBLIC_BIND=127.0.0.1

PYTHON_PERSISTENCE_BACKEND=local_pg
PIPELINE_USE_BRIGHTDATA_FASTMCP=true
PIPELINE_BRIGHTDATA_SHARED_CLIENT=true
ENTITY_IMPORT_QUEUE_MODE=durable_worker
ENTITY_PIPELINE_WORKER_POLL_SECONDS=10

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
BRIGHTDATA_API_TOKEN=

# Use this exact shape in Vercel Preview/Production, replacing the host with the Oracle public IP or DNS name.
# DATABASE_URL=postgresql://panther_staging:replace-with-a-long-random-password@<oracle-public-host>:5432/signal_noise_app?sslmode=require
