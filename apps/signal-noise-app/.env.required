# Required for CSV -> Phase 0..4 entity pipeline in durable worker mode

# Queue + status + artifact persistence
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Pipeline executor topology
FASTAPI_URL=http://localhost:8000
ENTITY_IMPORT_QUEUE_MODE=durable_worker

# Inference (current primary path: Chutes OpenAI-compatible chat completions)
LLM_PROVIDER=chutes_openai
CHUTES_API_KEY=
CHUTES_MODEL_PRIMARY=moonshotai/Kimi-K2.5-TEE
CHUTES_MODEL_SECONDARY=MiniMaxAI/MiniMax-M2.5-TEE
CHUTES_MODEL_TERTIARY=zai-org/GLM-5-TEE
CHUTES_FALLBACK_MODEL=moonshotai/Kimi-K2.5-TEE
CHUTES_BASE_URL=https://llm.chutes.ai/v1
CHUTES_STREAM_ENABLED=true
CHUTES_TIMEOUT_SECONDS=45
CHUTES_FALLBACK_TIMEOUT_SECONDS=90
CHUTES_STREAM_IDLE_TIMEOUT_SECONDS=45
CHUTES_MAX_RETRIES=1

# Discovery retrieval
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_API_URL=https://api.brightdata.com
BRIGHTDATA_ZONE=
# Optional but recommended when SERP HTTP fallback is needed:
# BRIGHTDATA_SERP_ZONE=

# Temporal graph persistence
FALKORDB_URI=
FALKORDB_USER=falkordb
FALKORDB_PASSWORD=
FALKORDB_DATABASE=sports_intelligence
