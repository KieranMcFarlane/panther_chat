{
  "mcpServers": {
    "graph-mcp": {
      "command": "python3",
      "args": ["backend/falkordb_mcp_server_fastmcp.py"],
      "env": {
        "FALKORDB_URI": "${FALKORDB_URI}",
        "FALKORDB_USER": "${FALKORDB_USER}",
        "FALKORDB_PASSWORD": "${FALKORDB_PASSWORD}",
        "FALKORDB_DATABASE": "${FALKORDB_DATABASE}"
      }
    },
    "brightdata-mcp": {
      "command": "node",
      "args": ["scripts/brightdata-mcp-server.js"],
      "env": {
        "BRIGHTDATA_API_TOKEN": "${BRIGHTDATA_API_TOKEN}",
        "BRIGHTDATA_TOKEN": "${BRIGHTDATA_TOKEN}",
        "BRIGHTDATA_ZONE": "${BRIGHTDATA_ZONE}"
      }
    },
    "byterover-mcp": {
      "command": "npx",
      "args": ["-y", "@byterover/mcp"],
      "env": {
        "BYTEROVER_API_KEY": "${BYTEROVER_API_KEY}"
      }
    },
    "supabase-mcp": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest", "--project-ref=itlcuazbybqlkicsaola"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "chrome-mcp-server": {
      "type": "streamableHttp",
      "url": "http://127.0.0.1:12306/mcp"
    }
  }
}
