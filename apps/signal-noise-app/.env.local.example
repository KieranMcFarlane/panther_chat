# Local Development Environment Variables
# Copy this to .env.local for local testing

# Core Development
NODE_ENV=development
PORT=3005
HOSTNAME=0.0.0.0

# NextAuth (for local development)
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=local-dev-secret-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3005,http://127.0.0.1:3005

# Graph Configuration
FALKORDB_URI=redis://your-instance
FALKORDB_USER=default
FALKORDB_PASSWORD=your-password
FALKORDB_DATABASE=sports_intelligence

# AI Services
ANTHROPIC_API_KEY=your-claude-api-key
BRIGHTDATA_API_TOKEN=your-brightdata-token
PERPLEXITY_API_KEY=your-perplexity-key

# Development Tools
CHOKIDAR_USEPOLLING=true
FAST_REFRESH=true

# Graph -> Supabase sync scheduler
GRAPH_SYNC_BASE_URL=http://127.0.0.1:3005
GRAPH_SYNC_SCHEDULE=0 */6 * * *
GRAPH_SYNC_RUN_ON_START=true

# Reconciliation guardrails
RECON_MAX_EMBEDDINGS_NOT_IN_CACHED=0
RECON_MAX_ACTIONABLE_MISMATCHES=0
# Optional webhook for monitor/scheduler breaches
RECON_ALERT_WEBHOOK_URL=
