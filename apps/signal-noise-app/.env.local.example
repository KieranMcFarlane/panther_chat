# Local Development Environment Variables
# Copy this to .env.local for local testing

# Core Development
NODE_ENV=development
PORT=3005
HOSTNAME=0.0.0.0

# NextAuth (for local development)
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=local-dev-secret-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3005,http://127.0.0.1:3005

# Postgres
# Server-only. Do not create NEXT_PUBLIC_* variants for database URLs.
# Pull this from Vercel development envs with: vercel env pull .env.local
DATABASE_URL=postgresql://user:password@localhost:5432/signal_noise_dev
# Optional direct/admin URL for migrations or maintenance, when it differs from DATABASE_URL.
DATABASE_URL_UNPOOLED=postgresql://user:password@localhost:5432/signal_noise_dev
# Optional. Local development can use a larger pool than Vercel serverless.
PG_POOL_MAX=10

# Local Graphiti / FalkorDB
# Start with: npm run graphiti:falkordb:up
FALKORDB_URI=redis://localhost:6379
FALKORDB_USER=
FALKORDB_PASSWORD=
FALKORDB_DATABASE=sports_intelligence
GRAPHITI_MCP_URL=http://localhost:8000/mcp/
GRAPHITI_REQUIRED=0
GRAPHITI_SEMAPHORE_LIMIT=1
GRAPHITI_MEMORY_SYNC_TIMEOUT_MS=120000
GRAPHITI_DOSSIER_MEMORY_SYNC_CONCURRENCY=1
GRAPHITI_MEMORY_PAYLOAD_MODE=minimal_text
GRAPHITI_MEMORY_SYNC_BATCH_SIZE=1
GRAPHITI_MEMORY_SYNC_QUEUE_DELAY_MS=60000
GRAPHITI_MEMORY_SYNC_RETRY_ATTEMPTS=3
GRAPHITI_MEMORY_SYNC_RETRY_BASE_DELAY_MS=10000

# AI Services
ANTHROPIC_API_KEY=your-claude-api-key
BRIGHTDATA_API_TOKEN=your-brightdata-token
PERPLEXITY_API_KEY=your-perplexity-key

# Manus RFP wide-research import
MANUS_API=your-manus-api-key
# Full PEM public key from Manus webhook setup. Escaped \n newlines are supported.
MANUS_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<the full PEM public key>\n-----END PUBLIC KEY-----"
# Optional local/manual fallback when RSA signatures are unavailable.
MANUS_WEBHOOK_SECRET=your-random-local-webhook-secret

# Development Tools
CHOKIDAR_USEPOLLING=true
FAST_REFRESH=true
