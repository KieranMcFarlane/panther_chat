# Local Development Environment Variables
# Copy this to .env.local for local testing

# Core Development
NODE_ENV=development
PORT=3005
HOSTNAME=0.0.0.0

# NextAuth (for local development)
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=local-dev-secret-key-change-in-production

# CORS Configuration
CORS_ORIGIN=http://localhost:3005,http://127.0.0.1:3005

# Postgres
# Server-only. Do not create NEXT_PUBLIC_* variants for database URLs.
# Pull this from Vercel development envs with: vercel env pull .env.local
DATABASE_URL=postgresql://user:password@localhost:5432/signal_noise_dev
# Optional direct/admin URL for migrations or maintenance, when it differs from DATABASE_URL.
DATABASE_URL_UNPOOLED=postgresql://user:password@localhost:5432/signal_noise_dev
# Optional. Local development can use a larger pool than Vercel serverless.
PG_POOL_MAX=10

# MCP Server Configuration
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password

# AI Services
ANTHROPIC_API_KEY=your-claude-api-key
BRIGHTDATA_API_TOKEN=your-brightdata-token
PERPLEXITY_API_KEY=your-perplexity-key

# Development Tools
CHOKIDAR_USEPOLLING=true
FAST_REFRESH=true
