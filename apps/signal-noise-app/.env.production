# Production Environment Template
# Populate these values from your deployment secret store before use.

# Core API Configuration
NEXTAUTH_URL=https://your-domain.example
NEXTAUTH_SECRET=replace-with-production-secret
PORT=7668
HOSTNAME=0.0.0.0

# Claude / LLM Configuration
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Graph Configuration
FALKORDB_URI=redis://your-falkordb-instance
FALKORDB_USER=default
FALKORDB_PASSWORD=replace-with-falkordb-password
FALKORDB_DATABASE=sports_intelligence

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Bright Data
BRIGHTDATA_API_TOKEN=replace-with-brightdata-token
BRIGHTDATA_API_URL=https://api.brightdata.com

# Perplexity API
PERPLEXITY_API_KEY=replace-with-perplexity-api-key

# Processing Configuration
BATCH_SIZE=3
MEMORY_THRESHOLD_MB=512
MAX_CONCURRENT=2

# License
NEXT_PUBLIC_LICENSE_KEY=replace-with-license-key
