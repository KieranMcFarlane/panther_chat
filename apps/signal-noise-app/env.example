# Neo4j AuraDB Configuration
NEO4J_URI=neo4j+s://your-aura-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-password

# Redis Configuration
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://:your-redis-password@localhost:6379/0

# API Keys
CLAUDE_API_KEY=your-claude-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
BRIGHTDATA_API_KEY=your-brightdata-api-key

# Environment
ENVIRONMENT=production

# Application Settings
LOG_LEVEL=INFO
WORKER_CONCURRENCY=2
MAX_WORKERS=4

# Postgres
# Server-only. Do not create NEXT_PUBLIC_* variants for database URLs.
# Use the Oracle Postgres staging or local Postgres connection string for app/runtime queries.
DATABASE_URL=postgresql://user:password@postgres.example.com:5432/signal_noise?sslmode=require
# Optional direct/admin URL for migrations or maintenance, when it differs from DATABASE_URL.
DATABASE_URL_UNPOOLED=postgresql://user:password@postgres.example.com:5432/signal_noise?sslmode=require
# Optional. Defaults are lower on Vercel/serverless runtimes.
PG_POOL_MAX=5

# AWS Specific Settings
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Optional: local Unix-socket fallback for development only, when DATABASE_URL is unset.
# POSTGRES_DB=signal_noise
# POSTGRES_USER=signal_user
# POSTGRES_PASSWORD=signal_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql:///signal_noise_app?host=/tmp
