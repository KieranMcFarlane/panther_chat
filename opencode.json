{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-api/glm-5.1",
  "provider": {
    "zai-api": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Z.AI API",
      "options": {
        "baseURL": "https://api.z.ai/api/paas/v4",
        "apiKey": "{env:ZAI_API_KEY}"
      },
      "models": {
        "glm-5.1": {
          "id": "GLM-5.1",
          "name": "GLM-5.1",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    }
  },
  "permission": {
    "*": "allow",
    "bash": "deny",
    "edit": "deny"
  },
  "tools": {
    "brightData*": false,
    "brightdata*": false
  },
  "agent": {
    "build": {
      "tools": {
        "brightData*": true,
        "brightdata*": true
      }
    }
  },
  "mcp": {
    "brightData": {
      "type": "remote",
      "url": "http://127.0.0.1:8000/mcp/",
      "enabled": true,
      "timeout": 15000
    }
  }
}
